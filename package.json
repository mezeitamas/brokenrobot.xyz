{
    "name": "brokenrobot.xyz",
    "description": "Tamas Mezei's personal website.",
    "version": "3.0.0",
    "private": true,
    "author": "Tamas Mezei",
    "repository": {
        "type": "git",
        "url": "git@github.com:mezeitamas/brokenrobot.xyz.git"
    },
    "type": "module",
    "engines": {
        "node": ">=26.2.0",
        "npm": ">=11.13.0"
    },
    "scripts": {
        "install:playwright": "playwright install --with-deps",
        "clean": "rimraf dist/ reports/ .astro/ .cache/ test-results/ playwright-report/",
        "format:check": "prettier '**/*.{astro,js,jsx,ts,tsx,cjs,mjs,css,json,md,mdx,yml}' --check",
        "format:fix": "prettier '**/*.{astro,js,jsx,ts,tsx,cjs,mjs,css,json,md,mdx,yml}' --write",
        "lint:check": "astro sync && eslint 'src/**/*.{astro,ts,tsx}'",
        "type:check": "astro check && tsc --noEmit",
        "test:e2e:check": "playwright test",
        "test:e2e:update": "playwright test --update-snapshots",
        "audit:check": "npm audit --package-lock-only --omit=dev",
        "build": "astro build",
        "serve": "astro preview",
        "start": "astro dev",
        "astro": "astro"
    },
    "dependencies": {
        "@astrojs/check": "0.9.9",
        "@astrojs/mdx": "6.0.1",
        "@astrojs/preact": "5.1.5",
        "@astrojs/rss": "4.0.18",
        "@astrojs/sitemap": "3.7.3",
        "@astrojs/ts-plugin": "1.10.9",
        "@fontsource/newsreader": "5.2.10",
        "@fontsource/space-grotesk": "5.2.10",
        "@fontsource/space-mono": "5.2.9",
        "@tailwindcss/postcss": "4.3.0",
        "@tailwindcss/typography": "0.5.19",
        "astro": "6.4.2",
        "astro-feather": "1.0.0",
        "mdast-util-to-string": "4.0.0",
        "preact": "10.29.2",
        "reading-time": "1.5.0",
        "schema-dts": "2.0.0",
        "tailwindcss": "4.3.0"
    },
    "devDependencies": {
        "@axe-core/playwright": "4.11.3",
        "@playwright/test": "1.60.0",
        "@types/mdast": "4.0.4",
        "@typescript-eslint/eslint-plugin": "8.60.0",
        "@typescript-eslint/parser": "8.60.0",
        "autoprefixer": "10.5.0",
        "dotenv": "17.4.2",
        "eslint": "8.57.0",
        "eslint-import-resolver-typescript": "4.4.5",
        "eslint-plugin-astro": "1.7.0",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-jsx-a11y": "6.10.2",
        "postcss-import": "16.1.1",
        "postcss-nesting": "14.0.0",
        "prettier": "3.8.3",
        "prettier-plugin-astro": "0.14.1",
        "prettier-plugin-sh": "0.18.1",
        "prettier-plugin-tailwindcss": "0.8.0",
        "rimraf": "6.1.3",
        "typescript": "6.0.3"
    }
}
