---
import '@styles/base.css';

import { Font } from 'astro:assets';

import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';

import { SITE_METADATA } from '../consts';

type Props = {
    pageTitle: string;
    pageDescription: string;
};

const { pageTitle, pageDescription } = Astro.props;

// Resolve the theme before first paint to avoid a flash of the wrong theme.
// Kept as an inline string so it runs synchronously in <head> (CSP allows inline scripts).
const themeInitScript = `(function () {
  try {
    var stored = localStorage.getItem('theme');
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    document.documentElement.dataset.theme =
      stored === 'light' || stored === 'dark' ? stored : prefersDark ? 'dark' : 'light';
  } catch (e) {
    document.documentElement.dataset.theme = 'light';
  }
})();`;
---

<!doctype html>
<html
    lang={SITE_METADATA.LANGUAGE}
    dir={SITE_METADATA.DIR}
>
    <head>
        <script
            is:inline
            set:html={themeInitScript}
        />

        <meta charset="utf-8" />
        <meta
            name="viewport"
            content="width=device-width,initial-scale=1"
        />
        <meta
            name="generator"
            content={Astro.generator}
        />
        <meta
            name="theme-color"
            media="(prefers-color-scheme: light)"
            content="#faf7f2"
        />
        <meta
            name="theme-color"
            media="(prefers-color-scheme: dark)"
            content="#17150f"
        />
        <link
            rel="sitemap"
            href="/sitemap-index.xml"
        />
        <link
            rel="alternate"
            type="application/rss+xml"
            title={SITE_METADATA.TITLE}
            href="/rss.xml"
        />
        <link
            rel="canonical"
            href={Astro.url}
        />
        <link
            rel="icon"
            type="image/svg+xml"
            href="/favicon.svg"
        />

        <Font
            cssVariable="--font-space-grotesk"
            preload
        />
        <Font cssVariable="--font-newsreader" />
        <Font cssVariable="--font-space-mono" />

        <title>{pageTitle}</title>
        <meta
            name="title"
            content={pageTitle}
        />
        <meta
            name="author"
            content={SITE_METADATA.AUTHOR.NAME}
        />
        <meta
            name="description"
            content={pageDescription}
        />

        <slot name="seo" />
    </head>

    <body>
        <Header />

        <main class="prose md:prose-lg lg:prose-xl mx-auto my-10 max-w-screen-xl px-4 md:px-6 lg:px-8">
            <slot name="content" />
        </main>

        <Footer
            githubLink={SITE_METADATA.AUTHOR.SOCIAL.GITHUB_URL}
            linkedinLink={SITE_METADATA.AUTHOR.SOCIAL.LINKEDIN_URL}
            blueskyLink={SITE_METADATA.AUTHOR.SOCIAL.BLUESKY_URL}
            mastodonLink={SITE_METADATA.AUTHOR.SOCIAL.MASTODON_URL}
            authorName={SITE_METADATA.AUTHOR.NAME}
        />
    </body>
</html>
