---
// Theme toggle. The correct icon is chosen by CSS from `html[data-theme]` (set before
// paint by the inline init in BaseLayout), so it's right on the first frame — no flash.
// The bundled script below only wires the click; it loads from `self` (CSP-safe).
---

<button
    id="theme-toggle"
    type="button"
    class="theme-toggle border-border bg-surface text-text hover:border-accent inline-grid h-10 w-10 cursor-pointer place-items-center rounded-[10px] border transition-colors"
    aria-label="Toggle light and dark theme"
>
    <svg
        class="icon-moon"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
    >
        <path d="M20 14.5A8 8 0 1 1 9.5 4a6.3 6.3 0 0 0 10.5 10.5Z"></path>
    </svg>
    <svg
        class="icon-sun"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
    >
        <circle
            cx="12"
            cy="12"
            r="4.2"
        ></circle>
        <path
            d="M12 2.5v2.4M12 19.1v2.4M4.2 4.2l1.7 1.7M18.1 18.1l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.2 19.8l1.7-1.7M18.1 5.9l1.7-1.7"
        ></path>
    </svg>
</button>

<style>
    /* Light (default): show the moon (click → dark). Dark: show the sun (click → light). */
    .icon-sun {
        display: none;
    }
    :global(html[data-theme='dark']) .icon-sun {
        display: block;
    }
    :global(html[data-theme='dark']) .icon-moon {
        display: none;
    }
</style>

<script>
    import './theme-toggle';
</script>
