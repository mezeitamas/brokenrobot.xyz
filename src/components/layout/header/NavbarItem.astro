---
type Props = {
    title: string;
    href: string;
    Icon: any;
};

const { title, href, Icon } = Astro.props;
---

<a
    href={href}
    class="inline-flex h-12 min-h-12 shrink-0 flex-wrap items-center justify-center gap-2 rounded-xl px-4 text-center hover:bg-slate-100 focus:bg-slate-100"
>
    <Icon size={16} />
    <span>{title}</span>
</a>
