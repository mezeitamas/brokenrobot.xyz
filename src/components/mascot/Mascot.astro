<style>
    .mascot {
        display: inline-block;
        color: var(--text);
    }

    .fill-ink {
        fill: currentColor;
    }
    .stroke-ink {
        stroke: currentColor;
    }
    .fill-body {
        fill: var(--surface);
    }
    .fill-limb {
        fill: color-mix(in srgb, var(--text) 30%, var(--surface));
    }
    .stroke-limb {
        stroke: color-mix(in srgb, var(--text) 30%, var(--surface));
    }
    .fill-accent {
        fill: var(--accent);
    }
    .stroke-accent {
        stroke: var(--accent);
    }
    .fill-screen {
        fill: color-mix(in srgb, var(--text) 9%, var(--surface));
    }

    @keyframes br-wobble {
        0%,
        100% {
            transform: rotate(-1.5deg);
        }
        50% {
            transform: rotate(1.5deg);
        }
    }
    @keyframes br-blink {
        0%,
        92%,
        100% {
            transform: scaleY(1);
        }
        96% {
            transform: scaleY(0.1);
        }
    }
    @keyframes br-antenna {
        0%,
        100% {
            transform: rotate(-7deg);
        }
        50% {
            transform: rotate(9deg);
        }
    }
    @keyframes br-spark {
        0%,
        100% {
            opacity: 0.2;
            transform: scale(0.7);
        }
        50% {
            opacity: 1;
            transform: scale(1.15);
        }
    }
    @keyframes br-smoke {
        0% {
            opacity: 0;
            transform: translate(0, 5px) scale(0.55);
        }
        28% {
            opacity: 0.5;
        }
        100% {
            opacity: 0;
            transform: translate(7px, -18px) scale(1.15);
        }
    }

    .mascot.anim .m-body {
        animation: br-wobble 5.5s ease-in-out infinite;
        transform-origin: 50% 90%;
    }
    .mascot.anim .m-eye {
        animation: br-blink 4.2s ease-in-out infinite;
        transform-origin: center;
        transform-box: fill-box;
    }
    .mascot.anim .m-antenna {
        animation: br-antenna 3.2s ease-in-out infinite;
        transform-origin: bottom;
        transform-box: fill-box;
    }
    .mascot.anim .m-spark {
        animation: br-spark 1.6s ease-in-out infinite;
        transform-origin: center;
        transform-box: fill-box;
    }
    .mascot.anim .m-smoke > * {
        animation: br-smoke 2.9s ease-out infinite;
    }
    .mascot.anim .m-smoke > *:nth-child(2) {
        animation-delay: 0.6s;
    }
    .mascot.anim .m-smoke > *:nth-child(3) {
        animation-delay: 1.2s;
    }

    @media (prefers-reduced-motion: reduce) {
        .mascot.anim * {
            animation: none !important;
        }
    }
</style>
