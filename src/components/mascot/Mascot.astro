const isHead = pose === 'head';
const is404 = pose === 'sit404';

const svgClass = ['mascot', animate ? 'anim' : null, className].filter(Boolean).join(' ');

const a11y = decorative ? { 'aria-hidden': 'true' as const } : { role: 'img' as const, 'aria-label': label };
