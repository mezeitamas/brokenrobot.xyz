{
    "extends": "astro/tsconfigs/strictest",
    "compilerOptions": {
        "noEmit": true,
        "strictNullChecks": true,
        "verbatimModuleSyntax": true,
        "baseUrl": ".",
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "paths": {
            "@assets/*": ["src/assets/*"],
            "@components/*": ["src/components/*"],
            "@fonts/*": ["src/fonts/*"],
            "@layouts/*": ["src/layouts/*"],
            "@styles/*": ["src/styles/*"]
        },
        "plugins": [
            {
                "name": "@astrojs/ts-plugin"
            }
        ]
    }
}
