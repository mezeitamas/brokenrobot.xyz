{
    "mcpServers": {
        "astro-docs": {
            "type": "http",
            "url": "https://mcp.docs.astro.build/mcp"
        },
        "playwright": {
            "command": "npx",
            "args": ["@playwright/mcp", "--browser=chrome", "--headless", "--isolated"]
        },
        "chrome-devtools": {
            "command": "npx",
            "args": ["chrome-devtools-mcp", "--headless", "--isolated"]
        },
        "terraform": {
            "command": "docker",
            "args": ["run", "-i", "--rm", "hashicorp/terraform-mcp-server:0.5.2", "--toolsets=registry"]
        },
        "github": {
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "GITHUB_PERSONAL_ACCESS_TOKEN",
                "-e",
                "GITHUB_READ_ONLY=1",
                "-e",
                "GITHUB_TOOLSETS=context,repos,issues,pull_requests,actions",
                "ghcr.io/github/github-mcp-server:v1.2.0"
            ]
        }
    }
}
