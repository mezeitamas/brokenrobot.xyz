{
    "name": "brokenrobot.xyz",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/node:2": {
            "version": "26.2.0"
        },
        "ghcr.io/devcontainers/features/terraform:1": {
            "version": "1.15.3"
        }
    },
    "mounts": [
        "source=${localWorkspaceFolderBasename}-node-modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
    ],
    "postCreateCommand": "sudo chown vscode:vscode node_modules && npm install && npm run install:playwright",
    "customizations": {
        "vscode": {
            "settings": {},
            "extensions": [
                "EditorConfig.EditorConfig",
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint",
                "astro-build.astro-vscode",
                "bradlc.vscode-tailwindcss",
                "hashicorp.terraform",
                "redhat.vscode-yaml",
                "ms-playwright.playwright",
                "unifiedjs.vscode-mdx"
            ]
        }
    }
}
